# AI Compliance NLWeb — local stack env. Copy to .env and tweak.
# Docker dashboard groups by this name (NOT "local"). PLAN.md §8.
COMPOSE_PROJECT_NAME=compliance

# local (Ollama + Qdrant) | azure (Azure OpenAI + Azure AI Search)
RUNTIME_PROFILE=local

# Backend: mock (offline; no model server) | real (use the active profile)
NLWEB_BACKEND=real

# Embedding dim sizes the local Qdrant collections. mxbai-embed-large = 1024.
EMBEDDING_DIM=1024

# --- local profile (Ollama + Qdrant) ---
OLLAMA_MODELS=qwen3:14b,mxbai-embed-large       # bootstrap pulls these
OLLAMA_MODEL_REASONING=qwen3:14b                # answer model
OLLAMA_MODEL_EMBEDDING=mxbai-embed-large        # 1024-d
OLLAMA_BASE_URL=http://ollama:11434/v1
QDRANT_URL=http://qdrant:6333
RERANKER_ENABLED=true
RERANKER_URL=http://reranker:80
UNSTRUCTURED_URL=http://unstructured:8000

# --- azure profile (Azure OpenAI + Azure AI Search; DefaultAzureCredential) ---
# OPENAI_ENDPOINT=https://<your-aoai>.openai.azure.com
# OPENAI_API_VERSION=2024-10-21
# OPENAI_DEPLOYMENT_REASONING=gpt-4.1
# OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-small   # 1536-d
# SEARCH_SERVICE_ENDPOINT=https://<your-search>.search.windows.net
# SEARCH_INDEX_DOCS=compliance-docs-index
# SEARCH_INDEX_CHUNKS=compliance-chunks-index

# --- security (ADR 0017) ---
AUTH_ENABLED=false                              # true -> require bearer tokens
AUTH_DEV_TOKEN=dev-local-token
# AUTH_TOKENS=tok1:ask:read,mcp:invoke;tok2:ask:read
CORS_ALLOW_ORIGINS=http://localhost:8088,http://127.0.0.1:8088
RATE_LIMIT_PER_MIN=120
RATE_LIMIT_BURST=60
